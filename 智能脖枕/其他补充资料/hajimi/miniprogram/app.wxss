page {
  --color-primary: #4a7c6f;
  --color-primary-light: #e8f0ed;
  --color-accent: #e8825c;
  --color-accent-light: #fef0ea;
  --color-bg: #f7f5f2;
  --color-card: #ffffff;
  --color-text: #2d2d2d;
  --color-text-secondary: #8a8a8a;
  --color-text-tertiary: #b8b8b8;
  --color-border: rgba(0, 0, 0, 0.06);
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --shadow-card: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  --shadow-card-hover: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);

  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "WenQuanYi Micro Hei", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  background: var(--color-bg);
  color: var(--color-text);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  -webkit-text-size-adjust: 100%;
  text-size-adjust: 100%;
  line-height: 1.6;
  letter-spacing: 0.5rpx;
  font-variant-numeric: tabular-nums;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}
