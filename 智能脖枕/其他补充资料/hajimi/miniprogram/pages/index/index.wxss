page {
  background: #f7f5f2;
  min-height: 100vh;
}

.scrollarea {
  height: 100vh;
  box-sizing: border-box;
}

.page {
  padding: 24rpx 28rpx 180rpx;
}

.svg-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  background: currentColor;
  -webkit-mask-size: contain;
  mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
}

