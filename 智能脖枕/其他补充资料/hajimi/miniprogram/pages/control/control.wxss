.section-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2d2d;
  padding: 24rpx 8rpx 16rpx;
  letter-spacing: 0.5rpx;
}

.section-label .svg-icon {
  color: #4a7c6f;
}

.mode-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.mode-card {
  padding: 24rpx 12rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.25s ease;
  border: 2rpx solid transparent;
}

.mode-card:active {
  transform: scale(0.96);
}

.mode-active {
  background: #e8f0ed;
  border-color: #4a7c6f;
}

.mode-emoji {
  font-size: 40rpx;
  line-height: 1;
}

.mode-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d2d2d;
  letter-spacing: 0.5rpx;
}

.mode-desc {
  font-size: 20rpx;
  color: #8a8a8a;
  letter-spacing: 0.3rpx;
}

.airbag-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.airbag-item {
  padding: 12rpx 0;
}

.airbag-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.airbag-name {
  font-size: 26rpx;
  color: #2d2d2d;
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.airbag-value {
  font-size: 24rpx;
  color: #4a7c6f;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

.airbag-slider {
  margin: 0;
  width: 100%;
}

.airbag-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.airbag-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  background: #f0ede8;
  color: #5a5a5a;
  border: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  line-height: normal;
  letter-spacing: 0.5rpx;
}

.airbag-btn::after {
  border: 0;
}

.airbag-btn .svg-icon {
  width: 28rpx;
  height: 28rpx;
}

.airbag-btn-primary {
  background: #4a7c6f;
  color: #ffffff;
}

.airbag-btn-primary .svg-icon {
  color: #ffffff;
}

.airbag-btn:active {
  transform: scale(0.97);
}

.massage-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.massage-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.massage-toggle-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2d2d;
  letter-spacing: 0.5rpx;
}

.massage-toggle-desc {
  font-size: 24rpx;
  color: #8a8a8a;
  margin-top: 4rpx;
  letter-spacing: 0.3rpx;
}

.massage-options {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.massage-row {
  margin-bottom: 24rpx;
}

.massage-row:last-child {
  margin-bottom: 0;
}

.massage-label {
  font-size: 24rpx;
  color: #8a8a8a;
  margin-bottom: 12rpx;
  letter-spacing: 0.3rpx;
}

.massage-chips {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.massage-chip {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #5a5a5a;
  background: #f0ede8;
  transition: all 0.2s ease;
  letter-spacing: 0.5rpx;
}

.chip-active {
  background: #4a7c6f;
  color: #ffffff;
}

.intensity-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.intensity-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #f0ede8;
  transition: all 0.2s ease;
}

.dot-filled {
  background: #4a7c6f;
  box-shadow: 0 0 12rpx rgba(74, 124, 111, 0.3);
}

.temp-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.temp-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.temp-toggle-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2d2d;
  letter-spacing: 0.5rpx;
}

.temp-toggle-desc {
  font-size: 24rpx;
  color: #8a8a8a;
  margin-top: 4rpx;
  letter-spacing: 0.3rpx;
}

.temp-control {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.temp-display {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.temp-current {
  font-size: 56rpx;
  font-weight: 700;
  color: #e8825c;
  font-variant-numeric: tabular-nums;
  letter-spacing: 1rpx;
}

.temp-target {
  font-size: 26rpx;
  color: #8a8a8a;
  letter-spacing: 0.3rpx;
}

.temp-presets {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.temp-preset {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #5a5a5a;
  background: #fef0ea;
  transition: all 0.2s ease;
  letter-spacing: 0.5rpx;
  font-variant-numeric: tabular-nums;
}

.preset-active {
  background: #e8825c;
  color: #ffffff;
}
