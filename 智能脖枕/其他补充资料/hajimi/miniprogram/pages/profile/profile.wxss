.device-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.device-info-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.device-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #e8f0ed;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.device-detail {
  flex: 1;
}

.device-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2d2d;
  letter-spacing: 0.5rpx;
}

.device-sn {
  font-size: 22rpx;
  color: #8a8a8a;
  margin-top: 4rpx;
  letter-spacing: 0.3rpx;
  font-variant-numeric: tabular-nums;
}

.device-status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-online {
  background: #4a7c6f;
  box-shadow: 0 0 12rpx rgba(74, 124, 111, 0.4);
}

.device-meta {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.device-meta-item {
  flex: 1;
  text-align: center;
}

.meta-label {
  font-size: 20rpx;
  color: #b8b8b8;
  letter-spacing: 0.3rpx;
}

.meta-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #2d2d2d;
  margin-top: 4rpx;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.meta-online {
  color: #4a7c6f;
}

.body-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.body-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.body-row:last-of-type {
  border-bottom: 0;
}

.body-label {
  font-size: 26rpx;
  color: #8a8a8a;
  letter-spacing: 0.3rpx;
}

.body-value {
  font-size: 26rpx;
  color: #2d2d2d;
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.body-edit {
  text-align: center;
  padding: 20rpx 0 4rpx;
  font-size: 26rpx;
  color: #4a7c6f;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  letter-spacing: 0.5rpx;
}

.settings-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.setting-item:last-child {
  border-bottom: 0;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.setting-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  background: #e8f0ed;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.setting-label {
  font-size: 28rpx;
  color: #2d2d2d;
  letter-spacing: 0.3rpx;
}

.setting-arrow {
  width: 20rpx;
  height: 20rpx;
  flex-shrink: 0;
}

.version {
  text-align: center;
  font-size: 22rpx;
  color: #b8b8b8;
  margin-top: 40rpx;
  padding-bottom: 20rpx;
  letter-spacing: 0.5rpx;
  font-variant-numeric: tabular-nums;
}
