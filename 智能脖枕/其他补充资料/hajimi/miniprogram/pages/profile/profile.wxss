page {
  background: #f7f5f2;
  min-height: 100vh;
}

.scrollarea {
  height: 100vh;
  box-sizing: border-box;
}

.page {
  padding: 16rpx 28rpx 180rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4a7c6f, #7ab5a5);
  flex-shrink: 0;
}

.profile-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d2d2d;
  letter-spacing: 1rpx;
}

.profile-desc {
  font-size: 24rpx;
  color: #8a8a8a;
  letter-spacing: 0.3rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: 20rpx;
  padding: 28rpx 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.profile-stat {
  text-align: center;
  flex: 1;
}

.profile-stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d2d2d;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.5rpx;
}

.profile-stat-label {
  font-size: 22rpx;
  color: #8a8a8a;
  margin-top: 4rpx;
  letter-spacing: 0.3rpx;
}

.profile-stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.06);
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2d2d;
  padding: 24rpx 8rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  letter-spacing: 0.5rpx;
}

.svg-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  background: currentColor;
  -webkit-mask-size: contain;
  mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
}

.stat-svg-icon {
  width: 36rpx;
  height: 36rpx;
  margin: 0 auto 8rpx;
  color: #4a7c6f;
}

.section-svg-icon {
  width: 32rpx;
  height: 32rpx;
  color: #4a7c6f;
}

.device-svg-icon {
  width: 36rpx;
  height: 36rpx;
  color: #4a7c6f;
}

.edit-svg-icon {
  width: 26rpx;
  height: 26rpx;
  color: #4a7c6f;
}

.setting-svg-icon {
  width: 32rpx;
  height: 32rpx;
  color: #5a5a5a;
}

.arrow-svg-icon {
  width: 20rpx;
  height: 20rpx;
  color: #c0c0c0;
}

