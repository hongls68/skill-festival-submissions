<navigation-bar title="我的" back="{{false}}" color="#2d2d2d" background="#f7f5f2"></navigation-bar>
<scroll-view class="scrollarea" scroll-y>
  <view class="page">

    <view class="profile-card">
      <view class="avatar"></view>
      <view class="profile-info">
        <view class="profile-name">FLYF</view>
        <view class="profile-desc">已使用 {{useDays}} 天</view>
      </view>
    </view>

    <view class="stats-row">
      <view class="profile-stat">
        <view class="svg-icon stat-svg-icon icon-clock"></view>
        <view class="profile-stat-value">{{totalWear}}</view>
        <view class="profile-stat-label">累计佩戴</view>
      </view>
      <view class="profile-stat-divider"></view>
      <view class="profile-stat">
        <view class="svg-icon stat-svg-icon icon-hand"></view>
        <view class="profile-stat-value">{{totalMassage}}</view>
        <view class="profile-stat-label">按摩次数</view>
      </view>
      <view class="profile-stat-divider"></view>
      <view class="profile-stat">
        <view class="svg-icon stat-svg-icon icon-trending-up"></view>
        <view class="profile-stat-value">{{improvement}}</view>
        <view class="profile-stat-label">压力改善</view>
      </view>
    </view>

    <view class="section-label"><view class="svg-icon section-svg-icon icon-cpu"></view><text>我的设备</text></view>
    <view class="device-card">
      <view class="device-info-row">
        <view class="device-icon-wrap">
          <view class="svg-icon device-svg-icon icon-cpu"></view>
        </view>
        <view class="device-detail">
          <view class="device-name">FLYF的智能颈枕</view>
          <view class="device-sn">SN: HJM-2024-0816</view>
        </view>
        <view class="device-status-dot dot-online"></view>
      </view>
      <view class="device-meta">
        <view class="device-meta-item">
          <view class="meta-label">电量</view>
          <view class="meta-value">{{batteryLevel}}%</view>
        </view>
        <view class="device-meta-item">
          <view class="meta-label">固件</view>
          <view class="meta-value">v2.1.0</view>
        </view>
        <view class="device-meta-item">
          <view class="meta-label">连接</view>
          <view class="meta-value meta-online">已连接</view>
        </view>
      </view>
    </view>

    <view class="section-label"><view class="svg-icon section-svg-icon icon-user"></view><text>身体档案</text></view>
    <view class="body-card">
      <view class="body-row" wx:for="{{bodyInfo}}" wx:key="label">
        <view class="body-left">
          <view class="body-dot"></view>
          <view class="body-label">{{item.label}}</view>
        </view>
        <view class="body-value">{{item.value}}</view>
      </view>
      <view class="body-edit" bindtap="onEditBody"><view class="svg-icon edit-svg-icon icon-edit-3"></view><text>编辑档案</text></view>
    </view>

    <view class="section-label"><view class="svg-icon section-svg-icon icon-settings"></view><text>设置</text></view>
    <view class="settings-card">
      <view class="setting-item" wx:for="{{settings}}" wx:key="label" bindtap="onSettingTap">
        <view class="setting-left">
          <view class="svg-icon setting-svg-icon icon-setting-{{item.icon}}"></view>
          <text class="setting-label">{{item.label}}</text>
        </view>
        <view class="svg-icon arrow-svg-icon icon-chevron-right"></view>
      </view>
    </view>

    <view class="version">智能矫姿颈枕 v1.0.0</view>

  </view>
</scroll-view>
