<view class="tab-bar">
  <view
    class="tab-item {{selected === index ? 'active' : ''}}"
    wx:for="{{list}}"
    wx:key="index"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon icon-{{item.icon}}"></view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
