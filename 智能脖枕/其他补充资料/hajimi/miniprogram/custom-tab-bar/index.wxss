.tab-text {
  font-size: 20rpx;
  color: #999999;
  transition: color 0.2s ease;
  letter-spacing: 0.5rpx;
}

.active .tab-text {
  color: #4a7c6f;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.active .tab-icon {
  color: #4a7c6f;
}
