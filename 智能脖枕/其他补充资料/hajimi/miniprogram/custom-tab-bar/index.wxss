.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 110rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  gap: 6rpx;
  padding: 12rpx 0;
  transition: all 0.2s ease;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  transition: all 0.25s ease;
  opacity: 0.35;
}

.active .tab-icon {
  opacity: 1;
  transform: scale(1.08);
}

